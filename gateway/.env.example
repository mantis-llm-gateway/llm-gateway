# Copy to .env and fill in values for local development.
# In production (Fargate), these are injected from Parameter Store; .env is not present.

# Cache (Redis / Valkey)
# Local: leave as localhost. If semantic cache is enabled, use Redis Stack or
# another Redis-compatible cache with search/vector support.
# Production: ElastiCache primary endpoint, e.g. master.gw-hubert-cache.xxxxxx.use1.cache.amazonaws.com
CACHE_ENDPOINT=localhost
CACHE_PORT=6379
# Local Redis runs without auth; production uses ElastiCache AUTH token from Parameter Store.
# CACHE_AUTH_TOKEN=

# AWS / runtime
AWS_REGION=us-east-1
LOG_LEVEL=DEBUG
