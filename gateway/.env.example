# Copy to .env and fill in values for local development.
# In production (Fargate), these are injected from Parameter Store; .env is not present.

# Cache (Redis / Valkey)
# Local: leave as localhost. If semantic cache is enabled, use Redis Stack or
# another Redis-compatible cache with search/vector support.
# Production: ElastiCache primary endpoint, e.g. master.gw-hubert-cache.xxxxxx.use1.cache.amazonaws.com
CACHE_ENDPOINT=localhost
CACHE_PORT=6379
# Local Redis runs without auth; production uses ElastiCache AUTH token from Parameter Store.
# CACHE_AUTH_TOKEN=

# AWS / runtime
AWS_REGION=us-east-1
LOG_LEVEL=DEBUG

# Authentication
# Create a token shaped like gw_<token-id>_<random-secret>. Store only the SHA-256
# hash of its random secret. The setup_auth script provisions production values in SSM.
API_TOKEN_HASHES={"local-client":"<sha256-of-random-secret>"}
DASHBOARD_USERNAME=admin
# Generate with: uv run python -c 'from gateway.auth import hash_dashboard_password; import getpass; print(hash_dashboard_password(getpass.getpass()))'
DASHBOARD_PASSWORD_HASH=<argon2-password-hash>
