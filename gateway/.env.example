# Copy to .env and fill in values for local development.
# In production (Fargate), these are injected from Parameter Store; .env is not present.

# Cache (Redis / Valkey)
# Local: leave as localhost (matches `docker run redis:7 -p 6379:6379`).
# Production: ElastiCache primary endpoint, e.g. master.gw-hubert-cache.xxxxxx.use1.cache.amazonaws.com
CACHE_ENDPOINT=localhost
CACHE_PORT=6379
# Local Redis runs without auth; production uses ElastiCache AUTH token from Parameter Store.
# CACHE_AUTH_TOKEN=

# Gateway runtime
COOLDOWN_TTL_SECONDS=60

# AWS / runtime
AWS_REGION=us-east-1
LOG_LEVEL=DEBUG

# Provider API keys
# Currently read directly by engine.ProviderAdaptor via os.environ.
# Only OPENAI_API_KEY is read at the moment
# TODO: move into Settings so they're validated at startup.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
